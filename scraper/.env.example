# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/smartcart

# Redis
REDIS_URL=redis://localhost:6379

# Ambiente
NODE_ENV=development

# Scraping
SCRAPE_CONCURRENCY=2          # nº de lojas em paralelo
SCRAPE_DELAY_MS=2500          # delay entre requests (ms) — respeitar rate-limit
PRICE_ALERT_THRESHOLD=5       # % de variação para gerar alerta

# Cron (padrão: todos os dias às 06:00)
SCRAPE_CRON=0 6 * * *
