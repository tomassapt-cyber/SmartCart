{
  "name": "smartcart-scraper",
  "version": "1.0.0",
  "description": "Job diário de scraping de preços de cosmética PT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --transpile-only index.ts",
    "scrape:now": "ts-node --transpile-only index.ts --run-now",
    "seed": "ts-node --transpile-only ../db/seed.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.5",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
